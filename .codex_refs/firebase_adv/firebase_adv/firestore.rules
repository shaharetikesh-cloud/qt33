rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? userDoc().data.role
        : null;
    }

    function isSuperAdmin() {
      return userRole() == 'super_admin';
    }

    function isAdmin() {
      return isSuperAdmin() || userRole() == 'admin';
    }

    function isApprover() {
      return isAdmin() || userRole() == 'approver';
    }

    function isWriter() {
      return isApprover() || userRole() == 'data_entry';
    }

    function hasSubstationAccess(substationId) {
      return isAdmin()
        || (
          signedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && userDoc().data.substationIds != null
          && substationId in userDoc().data.substationIds
        );
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isSuperAdmin();
    }

    match /signupRequests/{requestId} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /substations/{substationId} {
      allow read: if true;
      allow create, update: if isWriter();
      allow delete: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if signedIn() && hasSubstationAccess(resource.data.substationId);
      allow create, update: if isWriter() && hasSubstationAccess(request.resource.data.substationId);
      allow delete: if isAdmin();
    }

    match /attendanceSheets/{sheetId} {
      allow read: if signedIn() && hasSubstationAccess(resource.data.substationId);
      allow create, update: if isWriter() && hasSubstationAccess(request.resource.data.substationId);
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}
