{
  "name": "unified_msedcl_workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "guard:legacy": "node scripts/ensure-project-root.mjs web-connected-canonical",
    "dev": "npm run guard:legacy && node scripts/dev-runner.mjs",
    "dev:web": "npm run guard:legacy && vite",
    "server:local": "npm run guard:legacy && node --env-file=.env server/index.js",
    "build": "npm run guard:legacy && vite build",
    "build:offline": "npm run guard:legacy && vite build --mode offline",
    "migrate:legacy:erp": "node scripts/migrate-legacy-to-erp-records.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "android:sync": "npm run guard:legacy && npx cap sync android",
    "android:open": "npm run guard:legacy && npx cap open android",
    "android:apk": "npm run android:apk:debug",
    "android:apk:debug": "npm run build && npm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:apk:debug:path": "powershell -NoProfile -Command \"Resolve-Path 'android/app/build/outputs/apk/debug/app-debug.apk'\"",
    "android:apk:path": "npm run android:apk:debug:path",
    "android:apk:release": "npm run build && npm run android:sync && cd android && gradlew.bat assembleRelease",
    "android:apk:release:path": "powershell -NoProfile -Command \"Resolve-Path 'android/app/build/outputs/apk/release/app-release-unsigned.apk'\"",
    "android:apk:release:signed:path": "powershell -NoProfile -Command \"if (Test-Path 'android/app/build/outputs/apk/release/app-release.apk') { Resolve-Path 'android/app/build/outputs/apk/release/app-release.apk' } else { Write-Output 'Signed release APK not found. Add android/keystore.properties and build release.' }\"",
    "android:aab": "npm run android:aab:release",
    "android:aab:release": "npm run build && npm run android:sync && cd android && gradlew.bat bundleRelease",
    "android:aab:release:path": "powershell -NoProfile -Command \"Resolve-Path 'android/app/build/outputs/bundle/release/app-release.aab'\"",
    "android:apk:offline": "node scripts/build-offline-apk.mjs",
    "android:apk:offline:path": "powershell -NoProfile -Command \"Resolve-Path 'android/app/build/outputs/apk/debug/unified-msedcl-offline-debug.apk'\""
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/app": "^7.1.2",
    "@capacitor/cli": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/network": "^7.0.4",
    "@capacitor/preferences": "^7.0.4",
    "@capacitor/share": "^7.0.4",
    "@capacitor/toast": "^7.0.4",
    "@supabase/supabase-js": "^2.57.4",
    "express": "^5.1.0",
    "firebase": "^12.12.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.9.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4"
  }
}
